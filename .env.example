# Supabase Self-Hosting Configuration
# Copier vers .env et modifier les valeurs

# Postgres
POSTGRES_PASSWORD=change_me

# JWT (générer avec: openssl rand -base64 64)
JWT_SECRET=change_me

# URL publique du VPS
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:8000

# Anon key (publique, visible côté client)
ANON_KEY=change_me

# Service key (privée, réservée admin)
SERVICE_KEY=change_me

# Désactiver la confirmation email
MAILER_AUTOCONFIRM=true
