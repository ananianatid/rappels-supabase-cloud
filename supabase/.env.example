# ─── Supabase Self-Hosting Configuration ────────────────────────
# Copier vers .env et modifier les valeurs

# Postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password

# JWT
# Générer avec: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_jwt_secret

# URL publique de votre API (domaine du VPS ou localhost)
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:8000

# Anon key — clé publique visible côté client
ANON_KEY=change_me_to_an_anon_key

# Service key — clé réservée aux opérations admin
SERVICE_KEY=change_me_to_a_service_key

# Désactiver la confirmation par email (pratique pour un usage perso)
MAILER_AUTOCONFIRM=true
